# ── Backend API ───────────────────────────────────────────────────────────────
# Kosongkan di development — Vite proxy otomatis forward /api/* ke localhost:3001
# Set ke URL production untuk build production:
#   VITE_API_URL=https://api.litostudio.id
VITE_API_URL=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Dari: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI yang perlu didaftarkan:
#   http://localhost:3001/api/v1/auth/callback   (dev)
#   https://api.litostudio.id/api/v1/auth/callback  (production)
REACT_OAUTH_CLIENT_ID=
